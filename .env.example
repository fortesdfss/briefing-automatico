# ============================================================
# .env.example — template SEM credenciais. Copia pra .env e preenche.
# IMPORTANTE: nunca commite o .env (já tá no .gitignore).
# Só preenche o que for usar pro SEU relogio.
# ============================================================

# --- Garmin (unofficial - python-garminconnect) ---
# Aviso: lib comunitaria. Pode quebrar a qualquer update da Garmin.
GARMIN_EMAIL=
GARMIN_PASSWORD=
# Se a conta tem 2FA via Authenticator app:
GARMIN_TOTP_SECRET=

# --- Polar (OFICIAL - Accesslink API) ---
# Crie app em https://www.polar.com/accesslink-api/
POLAR_CLIENT_ID=
POLAR_CLIENT_SECRET=
POLAR_ACCESS_TOKEN=

# --- Strava (OFICIAL - usado pelo conector Coros via sync) ---
# Crie app em https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# --- Coros (OFICIAL - API direta, requer dev access) ---
# Solicite acesso em https://apply.coros.com
COROS_CLIENT_ID=
COROS_CLIENT_SECRET=

# --- Apple Health (sem credencial - usa export local via iCloud) ---
# Configure o caminho da pasta com os JSONs exportados pelo Health Auto Export
APPLE_HEALTH_EXPORT_PATH=~/Library/Mobile\ Documents/com~apple~CloudDocs/HealthExports

# --- Amazfit (sem credencial direta - usa fluxo Apple Health) ---
# Mesma config do APPLE_HEALTH_EXPORT_PATH acima.

# --- IA (opcional - se rodar Claude/OpenAI via API em vez de IA local) ---
# Se voce roda Claude Code local, nao precisa preencher.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Geral ---
# Pasta onde o briefing diario (.md) vai ser gravado
BRIEFING_OUTPUT_DIR=./briefings
# Timezone (usado pelo scheduler)
TIMEZONE=America/Sao_Paulo
